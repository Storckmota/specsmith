# SpecSmith Environment Configuration
# Copy this to .env.local for local development: cp .env.example .env.local
# Never commit .env.local — it is already in .gitignore.

# ─── Provider mode ────────────────────────────────────────────────────────────
# mock  → no API keys required, returns fixture outputs (default, always works)
# api   → calls any OpenAI-compatible API (requires API_KEY)
# amd   → calls vLLM on AMD Developer Cloud (planned, not active yet)
PROVIDER=mock

# ─── API mode (PROVIDER=api) ──────────────────────────────────────────────────
# API_KEY is required. If missing, the app fails fast with a clear error.
# API_BASE_URL defaults to https://api.openai.com/v1 if not set.
# Any OpenAI-compatible endpoint works: OpenAI, Together, Fireworks, OpenRouter, local vLLM, etc.
#
# ── Public Vercel demo (recommended — Qwen 7B via OpenRouter) ─────────────────
# qwen/qwen-2.5-7b-instruct is used for the public demo: fast enough for Vercel
# Hobby function limits with ENABLE_PROVIDER_FALLBACK=true as a safety net.
# qwen/qwen-2.5-72b-instruct was validated end-to-end (score 95/100) but took
# ~325 seconds — far too slow for Vercel. Use 7B for public deploy.
#
# API_KEY=your_openrouter_key_here
# API_BASE_URL=https://openrouter.ai/api/v1
# API_MODEL=qwen/qwen-2.5-7b-instruct
#
# ── Controlled local validation (OpenAI) ──────────────────────────────────────
# API_KEY=sk-...
# API_BASE_URL=https://api.openai.com/v1
# API_MODEL=gpt-4o-mini

# ─── API call timeout (PROVIDER=api only) ────────────────────────────────────
# Per-provider-call timeout in milliseconds. The pipeline makes up to 5
# sequential calls, so the total pipeline time is at most:
#   (number of successful calls × actual latency) + first-failure timeout.
#
# For Vercel Hobby (10s function limit), set to 8000 so the fallback fires
# well before Vercel kills the function:
#   API_TIMEOUT_MS=8000
#
# For supervised local demos with large models (72B, gpt-4o, etc.) where you
# want real output, raise to 60000–90000:
#   API_TIMEOUT_MS=60000
#
# Default if not set: 30000 (30s).
#
# API_TIMEOUT_MS=8000

# ─── Provider fallback (PROVIDER=api only) ────────────────────────────────────
# If PROVIDER=api, the pipeline falls back to mock output when the provider call
# fails (timeout, network error, bad model output). Default: enabled (opt-out).
# The response sets providerMode to "API mode → Mock fallback" — never silent.
# Set to false only for strict API-only mode where you want real errors surfaced.
#
# ENABLE_PROVIDER_FALLBACK=false   # uncomment to disable (default is enabled)

# ─── AMD mode (PROVIDER=amd) ─────────────────────────────────────────────────
# Points at a vLLM server running on AMD Developer Cloud (planned, not active).
# AMD_ENDPOINT is required when PROVIDER=amd.
#
# AMD_ENDPOINT=http://<amd-cloud-ip>:8000
# AMD_MODEL=Qwen/Qwen2.5-72B-Instruct

# ─── Debug (local development only) ──────────────────────────────────────────
# Set to true locally to include raw model output in parse error messages.
# Leave unset or false in production — parse errors return generic messages.
#
# DEBUG_AGENT_OUTPUT=false
