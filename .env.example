# SpecSmith Environment Configuration
# Copy this to .env.local for local development: cp .env.example .env.local
# Never commit .env.local — it is already in .gitignore.

# ─── Provider mode ────────────────────────────────────────────────────────────
# mock  → no API keys required, returns fixture outputs (default, always works)
# api   → calls any OpenAI-compatible API (requires API_KEY)
# amd   → calls vLLM on AMD Developer Cloud (planned, not active yet)
PROVIDER=mock

# ─── API mode (PROVIDER=api) ──────────────────────────────────────────────────
# API_KEY is required. If missing, the app fails fast with a clear error.
# API_BASE_URL defaults to https://api.openai.com/v1 if not set.
# Any OpenAI-compatible endpoint works: OpenAI, Together, Fireworks, OpenRouter, local vLLM, etc.
#
# ── Public Vercel Hobby demo — API Fast Mode (single call, context-aware) ────
# PUBLIC_DEMO_FAST_MODE=true activates a single-call analysis path.
# One model call generates the full Forge Report (risks, tests, coverage, test
# file). Output is based on the user's actual spec — not canned mock data.
# This fits within Vercel Hobby's function time limits.
#
# API_KEY=your_openai_key_here
# API_BASE_URL=https://api.openai.com/v1
# API_MODEL=gpt-4.1-nano
# API_TIMEOUT_MS=25000
# API_ROUTE_TIMEOUT_MS=50000
# PUBLIC_DEMO_FAST_MODE=true
# ENABLE_PROVIDER_FALLBACK=false
# DEBUG_AGENT_OUTPUT=false
#
# To use Qwen via OpenRouter instead (validated, not the production default):
# API_KEY=your_openrouter_key_here
# API_BASE_URL=https://openrouter.ai/api/v1
# API_MODEL=qwen/qwen-2.5-7b-instruct
#
# ── Full 5-agent pipeline (local / controlled validation) ─────────────────────
# Leave PUBLIC_DEMO_FAST_MODE unset (or false) to run the full pipeline.
# Suitable for local demos and supervised validation runs.
#
# API_KEY=sk-...
# API_BASE_URL=https://api.openai.com/v1
# API_MODEL=gpt-4o-mini
# API_TIMEOUT_MS=60000
# API_ROUTE_TIMEOUT_MS=120000
# PUBLIC_DEMO_FAST_MODE=false

# ─── API call timeout (PROVIDER=api only) ────────────────────────────────────
# Per-provider-call timeout in milliseconds. Each model call is aborted after
# this many ms. The pipeline makes up to 5 sequential calls (more during the
# revision loop), so individual call latency accumulates.
#
# For Vercel Hobby (10s function limit), use 8000. Pair with API_ROUTE_TIMEOUT_MS
# to ensure the app returns a JSON 504 before Vercel returns an HTML timeout page.
#
# Default if not set: 30000 (30s).
#
# API_TIMEOUT_MS=8000

# ─── Public demo fast mode ────────────────────────────────────────────────────
# When PROVIDER=api and PUBLIC_DEMO_FAST_MODE=true, /api/analyze uses a single
# Qwen call to generate the full Forge Report. This is fast enough for Vercel
# Hobby and always returns context-aware output based on the user's actual spec.
#
# When false or unset: the full 5-agent pipeline runs (multi-call, slower).
#
# PUBLIC_DEMO_FAST_MODE=true

# ─── Route deadline (PROVIDER=api only) ──────────────────────────────────────
# Total route deadline in milliseconds. If the pipeline hasn't completed within
# this window, /api/analyze returns HTTP 504 JSON instead of letting Vercel
# return an HTML timeout page.
#
# Fast mode (single call): set to 50000 (50s) — well within Vercel Pro/Hobby
# limit of 60s. The call itself is bounded by API_TIMEOUT_MS (25s).
#
# Full pipeline mode: set to 60000–120000 for local/Pro use.
#
# Default if not set: 50000 when PUBLIC_DEMO_FAST_MODE=true, 7000 otherwise.
#
# API_ROUTE_TIMEOUT_MS=50000

# ─── Provider fallback (PROVIDER=api only) ────────────────────────────────────
# Controls what happens when PROVIDER=api and the pipeline fails (timeout,
# network error, model parse failure).
#
# ENABLE_PROVIDER_FALLBACK=false (default):
#   Returns a controlled JSON error to the frontend. The user sees a friendly
#   error message. No canned mock output is returned. This is the correct
#   behavior for the public demo — the user gets honest feedback, not a fake
#   report that ignores their actual spec.
#
# ENABLE_PROVIDER_FALLBACK=true:
#   Returns mock output labeled "API mode → Mock fallback". Useful for internal
#   demos where a transparent canned fallback is acceptable and uptime matters
#   more than result authenticity.
#
# ENABLE_PROVIDER_FALLBACK=false

# ─── AMD mode (PROVIDER=amd) ─────────────────────────────────────────────────
# Points at a vLLM server running on AMD Developer Cloud (planned, not active).
# AMD_ENDPOINT is required when PROVIDER=amd.
#
# AMD_ENDPOINT=http://<amd-cloud-ip>:8000
# AMD_MODEL=Qwen/Qwen2.5-72B-Instruct

# ─── Debug (local development only) ──────────────────────────────────────────
# Set to true locally to include raw model output in parse error messages.
# Leave unset or false in production — parse errors return generic messages.
#
# DEBUG_AGENT_OUTPUT=false
