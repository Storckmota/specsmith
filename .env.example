# SpecSmith Environment Configuration
# Copy this to .env.local for local development

# Provider mode: mock | api | amd
# Default: mock (no API keys needed)
PROVIDER=mock

# API mode settings (PROVIDER=api)
# API_MODEL=gpt-4o
# API_BASE_URL=https://api.openai.com/v1
# API_KEY=sk-...

# AMD mode settings (PROVIDER=amd)
# AMD_ENDPOINT=http://<amd-cloud-ip>:8000
# AMD_MODEL=Qwen/Qwen2.5-72B-Instruct
